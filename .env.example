# ============================================================
# Nexora Customer Success Digital FTE — Environment Variables
# Stage 3 Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit the actual .env file (it is in .gitignore).

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./nexora_support.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/nexora_support

# ── AI / LLM Provider ───────────────────────────────────────
# Options: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Model to use (leave blank to use provider default)
# Anthropic default: claude-sonnet-4-6
# OpenAI default:    gpt-4o-mini
# Gemini default:    gemini-1.5-flash
LLM_MODEL=

# ── API Keys (set ONE based on LLM_PROVIDER) ────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ── Application ─────────────────────────────────────────────
APP_ENV=development
APP_VERSION=3.0.0
LOG_LEVEL=INFO

# ── Frontend (Next.js) ──────────────────────────────────────
# Set this in frontend/.env.local, not here.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Optional: Real Channel Integrations (Stage 4+) ──────────
# Uncomment when ready to integrate real channels.

# Gmail API
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=
# GMAIL_PUBSUB_TOPIC=

# Twilio WhatsApp Business
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Slack Notifications (for escalation alerts)
# SLACK_WEBHOOK_URL=
# SLACK_ESCALATION_CHANNEL=#customer-success-escalations

# ── Analytics Persistence ───────────────────────────────────
# File paths for JSON persistence (relative to project root)
METRICS_FILE=metrics_store.json
USAGE_FILE=usage_log.json
